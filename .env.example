# Configuracion de entorno para produccion en AWS
# Copiar este archivo a .env y reemplazar con los valores reales

# Base de datos RDS
DATABASE_URL=mysql+pymysql://admin:password@sicei-db.xxxxx.us-east-1.rds.amazonaws.com/sicei

# S3
S3_BUCKET=16001212-uady-aws-academy

# SNS
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:cuenta:sicei-notificaciones

# DynamoDB
DYNAMODB_TABLE=sesiones-alumnos

# Credenciales AWS (necesarias en EC2 para S3, SNS y DynamoDB)
AWS_ACCESS_KEY_ID=access_key
AWS_SECRET_ACCESS_KEY=secret_key
AWS_SESSION_TOKEN=session_token
